# Reuse the same Supabase project as the admin app.
# The app reads the active LIVE channel's stream_url from the `channels` table.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional fallback used when Supabase has no active live channel
# (or for quick local testing without the DB). Must be an HLS (.m3u8) URL.
VITE_LIVE_STREAM_URL=
